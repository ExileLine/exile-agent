ENV="环境标识"

DOCS_TITLE="API文档标题"
DOCS_DESCRIPTION="API文档描述"
DOCS_SUMMARY="API文档总结"
DOCS_VERSION="API文档版本"
DOCS_OPENAPI_URL="API文档版本.json地址"

SECRET_KEY=please-change-me
DEBUG=True
RUN_HOST=0.0.0.0
RUN_PORT=7777
SENSITIVE_HEADERS=authorization,cookie,set-cookie,x-api-key
DB_INIT_ON_STARTUP=True
REDIS_INIT_ON_STARTUP=True

DB_BACKEND=mysql

MYSQL_HOSTNAME=127.0.0.1
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-password
MYSQL_PORT=3306
MYSQL_DATABASE=database-name

POSTGRESQL_HOSTNAME=127.0.0.1
POSTGRESQL_USERNAME=postgres
POSTGRESQL_PASSWORD=your-password
POSTGRESQL_PORT=15432
POSTGRESQL_DATABASE=database-name

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=your-password
REDIS_DB=0
DECODE_RESPONSES=True

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_QUEUE="celery队列标识名称"

AI_ENABLED=True
AI_DEFAULT_AGENT=chat-agent
AI_DEFAULT_MODEL=openai:gpt-5.2
AI_MAX_RETRIES=2
AI_HTTP_TIMEOUT_SECONDS=30

AI_HISTORY_TTL_SECONDS="Redis存储对话历史过期时间单位`s`,`None`为永久"

OPENAI_API_KEY=大模型厂商API-KEY
OPENAI_BASE_URL=大模型厂商URL
